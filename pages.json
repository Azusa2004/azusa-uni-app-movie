			},
			{
				"pagePath": "pages/movie/movie",
				"text": "影院",
				"iconPath": "/static/building.png",
				"selectedIconPath": "/static/building-ac.png"
			},
			{
				"pagePath": "pages/mall/mall",
				"text": "影片",
				"iconPath": "/static/film.png",
				"selectedIconPath": "/static/film-ac.png"
			},
			{
				"pagePath": "pages/my/my",
				"text": "我的",
				"iconPath": "/static/myInfo.png",
				"selectedIconPath": "/static/myInfo-ac.png"
			}
		]
	},
	"uniIdRouter": {},
	
